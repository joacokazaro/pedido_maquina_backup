generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                Int               @id @default(autoincrement())
  username          String            @unique
  nombre            String?
  password          String?
  rol               String
  activo            Boolean           @default(true)
  vtoCarnetConductor DateTime?
  createdAt         DateTime          @default(now())

  // Relaciones
  historialAcciones HistorialPedido[]
  pedidosSupervisor Pedido[]          @relation("SupervisorPedidos")
  eventualesResponsable Eventual[]    @relation("SupervisorEventuales")
  serviciosAsignados UsuarioServicio[]
  roles             UsuarioRol[]
  notificaciones    Notificacion[]
  vehiculosAsignados Vehiculo[]       @relation("ConductorActualVehiculo")
  historialVehiculos VehiculoAsignacion[] @relation("VehiculoAsignadoAUsuario")
  asignacionesRealizadasVehiculo VehiculoAsignacion[] @relation("VehiculoAsignadoPorUsuario")
  historialEventuales HistorialEventual[]
  movimientosTaller TallerMovimiento[]
}

model UsuarioRol {
  id         Int      @id @default(autoincrement())
  usuarioId   Int
  rol        String
  createdAt  DateTime @default(now())

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rol])
  @@index([rol])
}

model Servicio {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  idBrowix  String?
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())

  // Relaciones
  maquinas     Maquina[] @relation("ServicioPrincipalMaquina")
  maquinasAmortizacion Maquina[] @relation("ServicioAmortizacionMaquina")
  historialMaquinas MaquinaServicioHistorial[]
  pedidos      Pedido[]
  supervisores UsuarioServicio[]
}

model Seguro {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  createdAt DateTime   @default(now())

  vehiculos Vehiculo[]
}

model UsuarioServicio {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  servicioId Int
  createdAt  DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  servicio Servicio @relation(fields: [servicioId], references: [id])

  @@unique([usuarioId, servicioId])
}

model Maquina {
  id           String          @id
  tipo         String
  tipoMaquinaId Int?
  modelo       String
  serie        String?
  estado       String          @default("disponible")
  servicioId   Int?
  fechaCompra  DateTime?
  proveedorFactura String?
  valorCompra  Float?
  empresa      String?
  anio         Int?
  amortizacion Int?
  estadoAmortizacion String @default("SIN_DATOS")
  antiguedad   Int?
  valorUsadaDolares Float?
  valorUsadaPesos Float?
  valorNuevaDolares Float?
  valorNuevaPesos Float?
  origenInfo   String?
  servicioAmortizacionId Int?
  comentarios  String?
  createdAt    DateTime        @default(now())

  // Relaciones
  servicio     Servicio?       @relation("ServicioPrincipalMaquina", fields: [servicioId], references: [id])
  servicioAmortizacion Servicio? @relation("ServicioAmortizacionMaquina", fields: [servicioAmortizacionId], references: [id])
  tipoMaquina  TipoMaquina?    @relation("MaquinaTipoMaquina", fields: [tipoMaquinaId], references: [id])
  asignaciones PedidoMaquina[]
  historialServicios MaquinaServicioHistorial[]
  movimientosTaller TallerMovimiento[]
}

model TipoMaquina {
  id                  Int                @id @default(autoincrement())
  nombre              String             @unique
  plazoAmortizacionId Int?
  createdAt           DateTime           @default(now())

  plazoAmortizacion   PlazoAmortizacion? @relation(fields: [plazoAmortizacionId], references: [id])
  maquinas            Maquina[]          @relation("MaquinaTipoMaquina")
  vehiculos           Vehiculo[]         @relation("VehiculoTipoMaquina")
  referencias         TipoMaquinaReferencia[]
}

model TipoMaquinaReferencia {
  id            Int          @id @default(autoincrement())
  tipoMaquinaId Int
  s3Key         String       @unique
  originalName   String?
  mimeType      String?
  descripcion   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tipoMaquina   TipoMaquina  @relation(fields: [tipoMaquinaId], references: [id], onDelete: Cascade)

  @@index([tipoMaquinaId, createdAt])
}

model PlazoAmortizacion {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  meses       Int
  createdAt   DateTime      @default(now())

  tiposMaquina TipoMaquina[]
}

model MaquinaServicioHistorial {
  id              Int      @id @default(autoincrement())
  maquinaId       String
  servicioId      Int
  fechaAsignacion DateTime @default(now())
  tipoMovimiento  String   @default("individual")

  maquina  Maquina  @relation(fields: [maquinaId], references: [id])
  servicio Servicio @relation(fields: [servicioId], references: [id])

  @@index([maquinaId, fechaAsignacion])
  @@index([servicioId])
}

model Vehiculo {
  id                      String               @id
  tipoMaquinaId           Int?
  empresa                 String
  estado                  String               @default("activo")
  vehiculo                String
  patente                 String               @unique
  modelo                  String
  numeroPoliza            String?
  motor                   String
  chasis                  String
  tipoCobertura           String
  seguroId                Int?
  conductorActualId       Int?
  vtoSeguro               DateTime?
  vtoSeguroAplica         Boolean              @default(true)
  vtoMatafuego            DateTime?
  vtoMatafuegoAplica      Boolean              @default(true)
  vtoItv                  DateTime?
  vtoItvAplica            Boolean              @default(true)
  obleaGnc                DateTime?
  obleaGncAplica          Boolean              @default(true)
  pruebaHidraulicaGnc     DateTime?
  pruebaHidraulicaGncAplica Boolean            @default(true)
  tarjetaVerde            Boolean              @default(false)
  createdAt               DateTime             @default(now())

  seguro                  Seguro?              @relation(fields: [seguroId], references: [id])
  tipoMaquina             TipoMaquina?         @relation("VehiculoTipoMaquina", fields: [tipoMaquinaId], references: [id])
  conductorActual         Usuario?             @relation("ConductorActualVehiculo", fields: [conductorActualId], references: [id])
  historialAsignaciones   VehiculoAsignacion[]
  asignacionesPedido      PedidoVehiculo[]
  movimientosTaller       TallerMovimiento[]
}

model TallerMovimiento {
  id         Int      @id @default(autoincrement())
  tipo       String
  maquinaId  String?
  vehiculoId String?
  accion     String
  observacion String?
  usuarioId  Int
  createdAt  DateTime @default(now())

  maquina    Maquina? @relation(fields: [maquinaId], references: [id])
  vehiculo   Vehiculo? @relation(fields: [vehiculoId], references: [id])
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([tipo, createdAt])
  @@index([maquinaId, createdAt])
  @@index([vehiculoId, createdAt])
  @@index([usuarioId, createdAt])
}

model Eventual {
  id            Int                 @id @default(autoincrement())
  nombre        String              @unique
  supervisorId  Int?
  estado        String              @default("activo")
  fechaInicio   DateTime?
  fechaFin      DateTime?
  observaciones String?
  maquinasUtilizadas String?
  vehiculosUtilizados String?
  componentesUtilizados String?
  trabajosRealizados    String?
  serviciosExtrasSubcontratados String?
  horasBrowix   String?
  insumosImportados String?
  horasSupervisor Float?
  activo        Boolean             @default(true)
  createdAt     DateTime            @default(now())

  supervisor    Usuario?            @relation("SupervisorEventuales", fields: [supervisorId], references: [id])
  historial     HistorialEventual[]
  pedidos       Pedido[]
}

model HistorialEventual {
  id         Int      @id @default(autoincrement())
  eventualId Int
  accion     String
  detalle    String?
  usuarioId  Int
  fecha      DateTime @default(now())

  eventual   Eventual @relation(fields: [eventualId], references: [id])
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([eventualId, fecha])
}

model VehiculoAsignacion {
  id            Int       @id @default(autoincrement())
  vehiculoId    String
  usuarioId     Int
  asignadoPorId Int?
  fechaDesde    DateTime  @default(now())
  fechaHasta    DateTime?
  observacion   String?

  vehiculo      Vehiculo  @relation(fields: [vehiculoId], references: [id])
  usuario       Usuario   @relation("VehiculoAsignadoAUsuario", fields: [usuarioId], references: [id])
  asignadoPor   Usuario?  @relation("VehiculoAsignadoPorUsuario", fields: [asignadoPorId], references: [id])

  @@index([vehiculoId, fechaHasta])
  @@index([usuarioId, fechaHasta])
}

model Pedido {
  id               String            @id
  estado           String
  observacion      String?
  itemsSolicitados String
  itemsDevueltos   String?
  supervisorId     Int
  servicioId       Int

  // 🔽 NUEVOS CAMPOS
  destino          String            @default("DEPOSITO")
  supervisorDestinoUsername String?

  // Pedido complementario disparado desde un eventual
  eventualId       Int?

  createdAt        DateTime          @default(now())

  // Relaciones
  historial  HistorialPedido[]
  asignadas  PedidoMaquina[]
  vehiculosAsignadas PedidoVehiculo[]
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  supervisor Usuario  @relation("SupervisorPedidos", fields: [supervisorId], references: [id])
  eventual   Eventual? @relation(fields: [eventualId], references: [id])
  notificaciones Notificacion[]
}


model PedidoMaquina {
  id        Int     @id @default(autoincrement())
  pedidoId  String
  maquinaId String

  pedido  Pedido  @relation(fields: [pedidoId], references: [id])
  maquina Maquina @relation(fields: [maquinaId], references: [id])

  @@unique([pedidoId, maquinaId])
}

model PedidoVehiculo {
  id         Int      @id @default(autoincrement())
  pedidoId   String
  vehiculoId String

  pedido   Pedido   @relation(fields: [pedidoId], references: [id])
  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id])

  @@unique([pedidoId, vehiculoId])
}

model HistorialPedido {
  id        Int      @id @default(autoincrement())
  pedidoId  String
  accion    String
  detalle   String?
  usuarioId Int
  fecha     DateTime @default(now())

  // Relaciones
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  pedidoId  String?
  tipo      String
  estado    String?
  mensaje   String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido? @relation(fields: [pedidoId], references: [id])

  @@index([usuarioId, leida])
  @@index([pedidoId])
}
